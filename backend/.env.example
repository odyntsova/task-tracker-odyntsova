# Database (server-based RDBMS)
DATABASE_URL="postgresql://user:password@localhost:5432/tracker"

# Auth
JWT_SECRET="change-me-in-production"

# Server
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV=development

# Email verification SMTP (spec requires supporting relay1.dataart.com).
# Leave SMTP_HOST unset in dev to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="no-reply@ticket-tracker.local"
